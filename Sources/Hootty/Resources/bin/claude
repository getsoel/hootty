#!/bin/bash
# Hootty claude wrapper — reports session ID so Hootty can track
# Claude Code sessions for title-based state detection.
# Outside Hootty, passes through to the real claude unchanged.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# Find the real claude binary, skipping our own directory
find_real_claude() {
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$SCRIPT_DIR" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through if not inside Hootty
if [[ -z "$HOOTTY_PANE_ID" ]]; then
    exec "$REAL_CLAUDE" "$@"
fi

# Pass through subcommands that don't support --settings
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Inject SessionStart hook to report session ID back to Hootty for resume support.
# Thinking/attention detection is handled by title watching (ClaudeTitleParser).
HOOKS_JSON='{"hooks":{"SessionStart":[{"hooks":[{"type":"command","command":"'"$SCRIPT_DIR"'/claude-session-hook"}]}]}}'

exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
